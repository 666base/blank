# Supabase cloud (create project at https://supabase.com/dashboard)
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: only for server-side admin tasks — NEVER in Blank app
# SUPABASE_SERVICE_ROLE_KEY=

# Optional local Supabase CLI (supabase start)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=from supabase status

# Legacy Docker API (optional health/config proxy)
BLANK_SERVER_PORT=3020
