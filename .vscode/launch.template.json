{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Blank Cloud",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "blank",
        "@blank/server",
        "dev"
      ]
    },
    {
      "name": "Lanuch Blank Web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "blank",
        "@blank/web",
        "dev"
      ]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug Blank Web",
      "url": "http://localhost:8080"
    }
  ]
}